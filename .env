# ============================================================================
# ProShop Microservices - Environment Variables
# ============================================================================
# This file is shared by all services via docker-compose env_file directive.
# Each service only uses the variables it needs.
# ============================================================================

# ─── General ─────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── MongoDB (Shared Instance) ──────────────────────────────────────────────
MONGO_URI=mongodb+srv://Isuru4043:Akalanka1999@cluster0.wb9vc.mongodb.net/ProShop?retryWrites=true&w=majority&appName=cluster0

# ─── JWT Secret (Shared across services for token verification) ─────────────
JWT_SECRET=abc123

# ─── Redis Event Bus ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Service URLs (for local development without Docker) ────────────────────
USER_SERVICE_URL=http://localhost:5001
PRODUCT_SERVICE_URL=http://localhost:5002
ORDER_SERVICE_URL=http://localhost:5003
